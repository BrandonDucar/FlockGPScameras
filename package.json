{
  "name": "flockgpscameras",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "dev:mobile": "pnpm --filter mobile start",
    "build:web": "pnpm --filter web build",
    "build:api": "pnpm --filter api build",
    "db:generate": "pnpm --filter @flockgps/db generate",
    "db:migrate": "pnpm --filter @flockgps/db migrate",
    "db:seed": "pnpm --filter @flockgps/db seed",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "@types/node": "^20.12.0",
    "prettier": "^3.3.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
