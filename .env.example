# Environment Variables — FlockGPScameras

# ─── Database ───────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/flockgps"
DIRECT_URL="postgresql://postgres:password@localhost:5432/flockgps"

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
# Or Upstash:
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="xxx"

# ─── API ────────────────────────────────────────────────────
API_PORT=3001
API_SECRET="change-me-in-production"
CORS_ORIGINS="http://localhost:3000,https://flockgpscameras.com"

# ─── Mapbox ─────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN="pk.eyJ1IjoiWU9VUl9VU0VSTkFNRSIsImEiOiJYWFgifQ.xxx"
MAPBOX_SECRET_TOKEN="sk.eyJ1IjoiWU9VUl9VU0VSTkFNRSIsImEiOiJYWFgifQ.xxx"

# ─── Cloudflare R2 (image uploads) ──────────────────────────
R2_ACCOUNT_ID="xxx"
R2_ACCESS_KEY_ID="xxx"
R2_SECRET_ACCESS_KEY="xxx"
R2_BUCKET_NAME="flockgps-images"
R2_PUBLIC_URL="https://images.flockgpscameras.com"

# ─── Auth (optional) ────────────────────────────────────────
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"

# ─── Rate Limiting ──────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
SUBMIT_RATE_LIMIT_MAX=5

# ─── Web App ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"
